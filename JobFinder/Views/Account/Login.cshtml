@model JobFinder.ViewModels.LoginViewModel
@{
    ViewData["Title"] = "Đăng nhập";
}

<section class="login-page">
    <div class="container">
        <div class="login-card">
            <div class="login-card__header">
                <span class="login-icon">🔒</span>
                <h1>Đăng nhập</h1>
            </div>

            <form asp-action="Login" asp-controller="Account" method="post" class="login-form">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="ModelOnly" class="login-error"></div>
                <div class="form-group">
                    <input asp-for="Username" placeholder="Tên đăng nhập" />
                    <span asp-validation-for="Username" class="field-error"></span>
                </div>
                <div class="form-group">
                    <input asp-for="Password" placeholder="Mật khẩu" />
                    <span asp-validation-for="Password" class="field-error"></span>
                </div>
                <button type="submit" class="primary-button primary-button--full">Đăng nhập</button>
            </form>

            <div class="login-hint">
                <p>Tài khoản mẫu Admin: <strong>admin / Admin@123</strong></p>
                <p>Tài khoản mẫu User: <strong>ungvien / User@123</strong></p>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
