<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - JobFinder</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <div class="site-shell">
        <header class="site-header">
            <div class="container header-inner">
                <a class="brand" asp-controller="Home" asp-action="Index">
                    <span class="brand-mark">J</span>
                    <span class="brand-text">JobFinder</span>
                </a>
                <nav class="main-nav">
                    <a asp-controller="Home" asp-action="Index">Trang chủ</a>
                    <a asp-controller="Job" asp-action="Index">Việc làm</a>
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <span class="user-pill">
                            <span class="user-pill__icon">👤</span>
                            <span>@User.Identity.Name</span>
                        </span>
                        <form asp-controller="Account" asp-action="Logout" method="post">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="nav-button">Đăng xuất</button>
                        </form>
                    }
                    else
                    {
                        <a asp-controller="Account" asp-action="Login">Đăng nhập</a>
                    }
                </nav>
            </div>
        </header>

        <main role="main">
            @RenderBody()
        </main>

        <footer class="site-footer">
            <div class="container footer-grid">
                <div>
                    <h3>JobFinder</h3>
                    <p>Tìm công việc mơ ước của bạn với trải nghiệm tuyển dụng hiện đại và nhanh chóng.</p>
                </div>
                <div>
                    <h4>Liên kết nhanh</h4>
                    <ul>
                        <li><a asp-controller="Home" asp-action="Index">Trang chủ</a></li>
                        <li><a asp-controller="Job" asp-action="Index">Danh sách việc làm</a></li>
                        <li><a asp-controller="Account" asp-action="Login">Đăng nhập</a></li>
                    </ul>
                </div>
                <div>
                    <h4>Liên hệ</h4>
                    <ul>
                        <li>Email: support@jobfinder.vn</li>
                        <li>Điện thoại: 023 456 789</li>
                        <li>Địa chỉ: Quận 1, TP. Hồ Chí Minh</li>
                    </ul>
                </div>
            </div>
            <div class="footer-bottom container">
                <span>© 2026 JobFinder. Bảo lưu mọi quyền.</span>
                <div class="social-links">
                    <a href="#" aria-label="Facebook">f</a>
                    <a href="#" aria-label="LinkedIn">in</a>
                    <a href="#" aria-label="Github">gh</a>
                </div>
            </div>
        </footer>
    </div>

    <button type="button" class="back-to-top" data-back-to-top aria-label="Lên đầu trang">↑</button>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
